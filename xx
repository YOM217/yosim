};

let allOpeners = [], queue = [], seenStack = [], stackPos = -1;
let currentItem = null, catFilter = "הכל";
let history    = JSON.parse(localStorage.getItem("oh_hist") || "[]");
let customList = JSON.parse(localStorage.getItem("oh_custom") || "[]");
let deleted    = JSON.parse(localStorage.getItem("oh_deleted") || "[]");

function isDeleted(t) { return deleted.indexOf(t) !== -1; }

function buildAll() {
  allOpeners = [];
  const cats = catFilter === "הכל" ? Object.keys(DB)
             : catFilter === "שלי" ? [] : [catFilter];
  cats.forEach(cat => {
    DB[cat].forEach(txt => { if (!isDeleted(txt)) allOpeners.push({ txt, cat }); });
  });
  if (catFilter === "הכל" || catFilter === "שלי") {
    customList.forEach(txt => { if (!isDeleted(txt)) allOpeners.push({ txt, cat: "שלי" }); });
  }
  shuffle(allOpeners);
  queue = [...allOpeners];
  seenStack = []; stackPos = -1;
}
function shuffle(a) {
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
}

function showItem(animate) {
  if (!currentItem) return;
  const card = document.getElementById("card");
  const el = document.getElementById("opener-text");
  const badge = document.getElementById("cat-badge");
  const topbar = document.getElementById("topbar");
  const numEl = document.getElementById("card-num");
  const color = CAT_COLOR[currentItem.cat] || "#e8365d";

  el.textContent = currentItem.txt;
  badge.textContent = currentItem.cat;
  badge.style.color = color;
  topbar.style.background = `linear-gradient(90deg, transparent, ${color}, transparent)`;
  numEl.textContent = `${stackPos + 1} / ${allOpeners.length}`;

  updateStats();
  updateBackBtn();

  if (animate) {
    card.classList.remove("anim-in", "anim-outL", "anim-outR", "anim-del");
    void card.offsetWidth;
    card.classList.add("anim-in");
  }
}

function updateStats() {
  document.getElementById("st-total").textContent = allOpeners.length;
  document.getElementById("st-seen").textContent = seenStack.length;
  document.getElementById("st-left").textContent = queue.length;
}
function updateBackBtn() {
  document.getElementById("back-btn").disabled = stackPos <= 0;
}
function updateTrashBadge() {
  const b = document.getElementById("trash-badge");
  if (deleted.length > 0) {
    b.style.display = "flex";
    b.textContent = deleted.length > 99 ? "99+" : deleted.length;
  } else { b.style.display = "none"; }
}

function nextOpener(dir) {
  const card = document.getElementById("card");

  if (stackPos < seenStack.length - 1) {
    stackPos++;
    currentItem = seenStack[stackPos];
    const cls = dir === "L" ? "anim-outL" : "anim-outR";
    card.classList.remove("anim-in");
    void card.offsetWidth;
    card.classList.add(cls);
    setTimeout(() => { card.classList.remove(cls); showItem(true); }, 220);
    return;
  }

  const cls = dir === "L" ? "anim-outL" : "anim-outR";
  card.classList.remove("anim-in");
  void card.offsetWidth;
  card.classList.add(cls);

  setTimeout(() => {
    if (queue.length === 0) {
      queue = allOpeners.filter(o => o !== currentItem);
      shuffle(queue);
      toast("🔄 סיימנו סיבוב, מתחיל מחדש");
    }
    if (queue.length === 0) {
      card.classList.remove(cls);
      toast("אין משפטים בקטגוריה זו");
      return;
    }
    const i = Math.floor(Math.random() * queue.length);
    currentItem = queue.splice(i, 1)[0];
    seenStack.push(currentItem);
    stackPos = seenStack.length - 1;
    card.classList.remove(cls);
    showItem(true);
  }, 220);
}

function prevOpener() {
  if (stackPos <= 0) return;
  const card = document.getElementById("card");
  card.classList.remove("anim-in");
  void card.offsetWidth;
  card.classList.add("anim-outR");
  setTimeout(() => {
    stackPos--;
    currentItem = seenStack[stackPos];
    card.classList.remove("anim-outR");
    showItem(true);
  }, 220);
}

function deleteCurrent() {
  if (!currentItem) return;
  const txt = currentItem.txt;
  if (!confirm(`למחוק לצמיתות?\n\n"${txt}"\n\nאפשר לשחזר מאיקון 🗑️ למעלה.`)) return;

  deleted.push(txt);
  localStorage.setItem("oh_deleted", JSON.stringify(deleted));
  updateTrashBadge();

  allOpeners = allOpeners.filter(o => o.txt !== txt);
  queue = queue.filter(o => o.txt !== txt);
  seenStack = seenStack.filter(o => o.txt !== txt);

  const card = document.getElementById("card");
  card.classList.remove("anim-in");
  void card.offsetWidth;
  card.classList.add("anim-del");

  setTimeout(() => {
    if (allOpeners.length === 0) {
      currentItem = null;
      document.getElementById("opener-text").textContent = "אין משפטים זמינים";
      card.classList.remove("anim-del");
      updateStats();
      return;
    }
    if (queue.length === 0) {
      queue = allOpeners.filter(o => o !== currentItem);
      shuffle(queue);
    }
    const i = Math.floor(Math.random() * queue.length);
    currentItem = queue.splice(i, 1)[0];
    seenStack.push(currentItem);
    stackPos = seenStack.length - 1;
    card.classList.remove("anim-del");
    showItem(true);
    toast("🗑️ נמחק לצמיתות");
  }, 300);
}

function openTrashModal() {
  const list = document.getElementById("deleted-list");
  list.innerHTML = "";
  if (deleted.length === 0) {
    const e = document.createElement("div");
    e.className = "deleted-empty";
    e.textContent = "אין משפטים שנמחקו";
    list.appendChild(e);
  } else {
    deleted.forEach((txt, idx) => {
      const d = document.createElement("div");
      d.className = "deleted-item";
      d.innerHTML = `
        <div class="deleted-text">${txt}</div>
        <button class="deleted-restore" onclick="restoreDeleted(${idx})">♻️ שחזר</button>
      `;
      list.appendChild(d);
    });
  }
  document.getElementById("trash-overlay").classList.add("open");
}
function closeTrashModal() { document.getElementById("trash-overlay").classList.remove("open"); }
function trashOverlayClick(e) { if (e.target === document.getElementById("trash-overlay")) closeTrashModal(); }
function restoreDeleted(idx) {
  deleted.splice(idx, 1);
  localStorage.setItem("oh_deleted", JSON.stringify(deleted));
  updateTrashBadge();
  buildAll();
  if (queue.length > 0) {
    const i = Math.floor(Math.random() * queue.length);
    currentItem = queue.splice(i, 1)[0];
    seenStack = [currentItem]; stackPos = 0;
    showItem(true);
  }
  openTrashModal();
  toast("♻️ שוחזר בהצלחה");
}

function copyAndLog() {
  if (!currentItem) return;
  copyToClipboard(currentItem.txt);
  addHistory(currentItem);
  toast("📋 הועתק!");
}
function copyToClipboard(txt) {
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(txt).catch(() => fallback(txt));
  } else { fallback(txt); }
}
function fallback(txt) {
  const ta = document.createElement("textarea");
  ta.value = txt;
  ta.style.cssText = "position:fixed;top:0;left:0;opacity:0;";
  document.body.appendChild(ta);
  ta.focus(); ta.select();
  document.execCommand("copy");
  document.body.removeChild(ta);
}

function addHistory(item) {
  const d = new Date();
  const ds = `${d.getDate()}/${d.getMonth()+1}  ${String(d.getHours()).padStart(2,"0")}:${String(d.getMinutes()).padStart(2,"0")}`;
  history.unshift({ txt: item.txt, cat: item.cat, date: ds });
  if (history.length > 3) history = history.slice(0, 3);
  localStorage.setItem("oh_hist", JSON.stringify(history));
  renderHistory();
}
function renderHistory() {
  const wrap = document.getElementById("hist-wrap");
  const empty = document.getElementById("hist-empty");
  if (history.length === 0) {
    empty.style.display = "block";
    wrap.innerHTML = ""; wrap.appendChild(empty);
    return;
  }
  wrap.innerHTML = "";
  history.forEach((h, i) => {
    const color = CAT_COLOR[h.cat] || "#e8365d";
    const div = document.createElement("div");
    div.className = "hist-item";
    div.innerHTML = `
      <div class="hist-stripe" style="background:${color}"></div>
      <div class="hist-body">
        <div class="hist-text">${h.txt}</div>
        <div class="hist-meta">
          <span class="hist-cat-dot" style="background:${color}"></span>
          <span>${h.cat}</span>
          <span style="opacity:.5">${h.date}</span>
        </div>
      </div>
      <button class="hist-copy-btn" onclick="copyHist(${i})">📋</button>
    `;
    wrap.appendChild(div);
  });
}
function copyHist(i) { copyToClipboard(history[i].txt); toast("📋 הועתק!"); }

function buildCats() {
  const wrap = document.getElementById("cats");
  const names = ["הכל", ...Object.keys(DB)];
  if (customList.length > 0) names.push("שלי");
  wrap.innerHTML = "";
  names.forEach(c => {
    const b = document.createElement("button");
    b.className = "cat-btn" + (c === catFilter ? " active" : "");
    b.textContent = c;
    const col = CAT_COLOR[c] || "#e8365d";
    if (c === catFilter) {
      b.style.background = `linear-gradient(135deg, ${col}, ${col}99)`;
      b.style.boxShadow = `0 4px 16px ${col}44`;
    }
    b.onclick = () => {
      catFilter = c;
      buildCats();
      buildAll();
      if (allOpeners.length === 0) {
        currentItem = null;
        document.getElementById("opener-text").textContent = "אין משפטים בקטגוריה זו";
        updateStats();
        return;
      }
      const i = Math.floor(Math.random() * queue.length);
      currentItem = queue.splice(i, 1)[0];
      seenStack = [currentItem]; stackPos = 0;
      showItem(true);
    };
    wrap.appendChild(b);
  });
}

function openModal() {
  document.getElementById("overlay").classList.add("open");
  const ta = document.getElementById("ta");
  ta.value = customList.join("\n");
  updateCount();
  setTimeout(() => ta.focus(), 350);
}
function closeModal() { document.getElementById("overlay").classList.remove("open"); }
function overlayClick(e) { if (e.target === document.getElementById("overlay")) closeModal(); }
function updateCount() {
  const lines = document.getElementById("ta").value
    .split("\n").filter(l => l.trim().length > 1);
  document.getElementById("ta-count").textContent = `${lines.length} משפטים`;
}
document.getElementById("ta").addEventListener("input", updateCount);
function saveCustom() {
  const lines = document.getElementById("ta").value
    .split("\n").map(l => l.trim()).filter(l => l.length > 2);
  customList = lines;
  localStorage.setItem("oh_custom", JSON.stringify(customList));
  closeModal();
  buildCats();
  buildAll();
  if (queue.length > 0) {
    const i = Math.floor(Math.random() * queue.length);
    currentItem = queue.splice(i, 1)[0];
    seenStack = [currentItem]; stackPos = 0;
    showItem(true);
  }
  toast(`✅ נשמרו ${lines.length} משפטים`);
}

let toastT;
function toast(msg) {
  const el = document.getElementById("toast");
  el.textContent = msg;
  el.classList.add("show");
  clearTimeout(toastT);
  toastT = setTimeout(() => el.classList.remove("show"), 2200);
}

let sx = 0, sy = 0;
const cardEl = document.getElementById("card");
cardEl.addEventListener("touchstart", e => {
  sx = e.touches[0].clientX; sy = e.touches[0].clientY;
}, { passive: true });
cardEl.addEventListener("touchend", e => {
  const dx = e.changedTouches[0].clientX - sx;
  const dy = Math.abs(e.changedTouches[0].clientY - sy);
  if (Math.abs(dx) > 50 && dy < 80) {
    if (dx < 0) nextOpener("L"); else prevOpener();
  }
}, { passive: true });

document.addEventListener("keydown", e => {
  if (e.key === "ArrowRight" || e.key === "ArrowDown" || e.key === " ") nextOpener("L");
  if (e.key === "ArrowLeft" || e.key === "ArrowUp") prevOpener();
  if (e.key === "c" || e.key === "C") copyAndLog();
  if (e.key === "Delete") deleteCurrent();
});

buildAll();
buildCats();
updateTrashBadge();
if (queue.length > 0) {
  const si = Math.floor(Math.random() * queue.length);
  currentItem = queue.splice(si, 1)[0];
  seenStack = [currentItem]; stackPos = 0;
  showItem(false);
}
renderHistory();
</script>
</body>
</html>