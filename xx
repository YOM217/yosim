const CAT_COLOR = {
  "חד ושנון":      "#e8365d",
  "סקרנות ועניין": "#a78bfa",
  "הומור חכם":     "#ff8c35",
  "ישיר ואותנטי":  "#38c9ff",
  "לילה ורגשי":    "#f59e0b",
  "מיסטי ועמוק":   "#34d399",
